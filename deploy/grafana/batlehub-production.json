{
  "title": "BatleHub — Production",
  "uid": "batlehub-production",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "timepicker": {
    "refresh_intervals": ["1m", "5m", "15m", "1h"],
    "time_options": ["1h", "6h", "24h", "7d", "30d"]
  },
  "panels": [
    {
      "id": 1,
      "title": "System Health",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 2,
      "title": "Instance Up",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 4, "h": 4 },
      "targets": [
        { "expr": "up{job=\"batlehub\"}", "legendFormat": "{{instance}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 1, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(batlehub_requests_total[5m])) by (outcome)",
          "legendFormat": "{{outcome}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 4,
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 1, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(batlehub_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(batlehub_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(batlehub_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 5,
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 4, "y": 9, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "rate(batlehub_requests_total{outcome=\"error\"}[5m]) / rate(batlehub_requests_total[5m])",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "DB Pool — Available Connections",
      "type": "timeseries",
      "gridPos": { "x": 14, "y": 9, "w": 10, "h": 8 },
      "targets": [
        {
          "expr": "batlehub_db_pool_available_connections",
          "legendFormat": "available"
        },
        {
          "expr": "batlehub_db_pool_size",
          "legendFormat": "max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 10,
      "title": "Cache Performance",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 17, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Cache Hit Rate by Registry",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(batlehub_artifact_cache_hits_total[5m])) by (registry) / (sum(rate(batlehub_artifact_cache_hits_total[5m])) by (registry) + sum(rate(batlehub_artifact_cache_misses_total[5m])) by (registry))",
          "legendFormat": "{{registry}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 12,
      "title": "Cache Bytes Stored",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "batlehub_cached_bytes_total",
          "legendFormat": "total cached"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 13,
      "title": "Upstream Fetch Errors",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 26, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "rate(batlehub_upstream_errors_total[5m])",
          "legendFormat": "{{registry}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 14,
      "title": "Cache Miss Rate by Registry (7d)",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 26, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "1 - (sum(increase(batlehub_artifact_cache_hits_total[7d])) by (registry) / (sum(increase(batlehub_artifact_cache_hits_total[7d])) by (registry) + sum(increase(batlehub_artifact_cache_misses_total[7d])) by (registry)))",
          "legendFormat": "{{registry}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },

    {
      "id": 20,
      "title": "Security",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 34, "w": 24, "h": 1 }
    },
    {
      "id": 21,
      "title": "Denied Requests (24h)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 35, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(batlehub_requests_total{outcome=\"denied\"}[24h]))",
          "legendFormat": "denied"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 22,
      "title": "Rate Limit Hits",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 35, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "rate(batlehub_rate_limit_hits_total[5m])",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 23,
      "title": "Auth Failures",
      "type": "timeseries",
      "gridPos": { "x": 15, "y": 35, "w": 9, "h": 8 },
      "targets": [
        {
          "expr": "rate(batlehub_auth_failures_total[5m])",
          "legendFormat": "{{reason}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },

    {
      "id": 30,
      "title": "Registry Breakdown",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 43, "w": 24, "h": 1 }
    },
    {
      "id": 31,
      "title": "Requests by Registry (24h)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 44, "w": 8, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(batlehub_requests_total[24h])) by (registry)",
          "legendFormat": "{{registry}}"
        }
      ]
    },
    {
      "id": 32,
      "title": "Downloads by Registry (7d)",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 44, "w": 16, "h": 8 },
      "targets": [
        {
          "expr": "sum(increase(batlehub_artifact_cache_hits_total[1h])) by (registry)",
          "legendFormat": "{{registry}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },

    {
      "id": 40,
      "title": "Quota & Rate Limits",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 52, "w": 24, "h": 1 }
    },
    {
      "id": 41,
      "title": "Quota Usage (top users)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 53, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, batlehub_quota_bytes_used)",
          "legendFormat": "{{user}} / {{registry}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 42,
      "title": "Quota Utilisation %",
      "type": "bargauge",
      "gridPos": { "x": 12, "y": 53, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "topk(10, batlehub_quota_bytes_used / batlehub_quota_bytes_limit)",
          "legendFormat": "{{user}} / {{registry}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.85 }
            ]
          }
        }
      }
    }
  ]
}
