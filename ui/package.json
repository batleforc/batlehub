{
  "name": "batlehub-ui",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "generate": "openapi-ts",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "lint:eslint": "eslint src --ext .ts,.vue",
    "lint:eslint:fix": "eslint src --ext .ts,.vue --fix",
    "format": "oxfmt --write src",
    "format:check": "oxfmt --check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@hey-api/client-fetch": "^0.13.1",
    "@lucide/vue": "^1.17.0",
    "@shikijs/core": "^4.1.0",
    "@shikijs/engine-javascript": "^4.1.0",
    "@shikijs/langs": "^4.1.0",
    "@shikijs/themes": "^4.1.0",
    "@vueuse/core": "^14.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "radix-vue": "^1.9.17",
    "shiki": "^4.1.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "vue": "^3.5.35",
    "vue-router": "^5.1.0"
  },
  "overrides": {
    "undici": "^7.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@hey-api/openapi-ts": "^0.99.0",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.8",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jsdom": "^29.1.1",
    "oxfmt": "^0.53.0",
    "oxlint": "^1.68.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.8",
    "vue-eslint-parser": "^10.0.0",
    "vue-tsc": "^3.3.3"
  }
}
