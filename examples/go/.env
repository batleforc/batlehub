# Set these before running `go get` / `go mod download`.
# The pipe-separated list is the GOPROXY fallback chain:
#   1. batlehub proxy (cached, authenticated)
#   2. direct (used only when a module is not in the proxy)
GOPROXY=http://localhost:8080/proxy/my-go/|direct

# Credentials: the proxy reads the Authorization header.
# go reads GONOSUMCHECK / GONOSUMDB to disable checksum verification for private modules.
GONOSUMDB=*
GONOSUMCHECK=*

# Pass the token via the standard GOAUTH env var (go 1.22+),
# or add it to ~/.netrc:
#   machine localhost login user password change-me-user-token
GOAUTH=netrc
