{
    "name": "my-org/my-app",
    "description": "A PHP application using a batlehub Composer proxy.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "symfony/console": "^7.0",
        "symfony/http-foundation": "^7.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "http://localhost:8080/proxy/my-composer/",
            "options": {
                "http": {
                    "header": [
                        "Authorization: Bearer change-me-user-token"
                    ]
                }
            }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    }
}
