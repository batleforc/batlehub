# Copy to ~/.terraformrc to redirect all provider downloads through batlehub.
#
# The network_mirror block tells Terraform to fetch providers from the proxy
# instead of registry.terraform.io.  The "direct" block with exclude prevents
# Terraform from falling back to the public registry for the same providers.

credentials "localhost:8080" {
  token = "change-me-user-token"
}

provider_installation {
  network_mirror {
    url     = "http://localhost:8080/proxy/my-terraform/"
    include = ["registry.terraform.io/*/*"]
  }

  direct {
    exclude = ["registry.terraform.io/*/*"]
  }
}
