# Copy to ~/.pypirc to configure twine for BatleHub.
#
# Publish:
#   python -m build
#   twine upload --repository batlehub dist/*
#
[distutils]
index-servers = batlehub

[batlehub]
repository = http://localhost:8080/proxy/my-private-pypi/legacy/
username = __token__
password = change-me-user-token
